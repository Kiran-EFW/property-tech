# =============================================================================
# PropTech Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# Server
SERVER_PORT=8080
ENVIRONMENT=dev  # dev, staging, prod

# Database (PostGIS)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/proptech?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET=change-me-in-production
JWT_EXPIRY=24h

# SMS Provider
SMS_PROVIDER=twilio
SMS_API_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SMTP / Email
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@proptech.in

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=proptech-webhook-verify

# FCM Push Notifications
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_KEY_PATH=
FCM_SERVICE_ACCOUNT_KEY=

# Cloudflare R2 Object Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_ACCESS_KEY_SECRET=
R2_BUCKET=proptech-uploads
R2_PUBLIC_URL=

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=proptech-dev-master-key

# Database Migrations
MIGRATIONS_PATH=migrations
AUTO_MIGRATE=true

# Rate Limiting
RATE_LIMIT_MAX=100
